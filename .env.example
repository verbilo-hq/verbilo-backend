# Database (Neon / PostgreSQL)
DATABASE_URL=

# AWS / Cognito
AWS_REGION=eu-north-1
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# CORS / Frontend origins
# Staging example: https://staging.verbilo.co.uk
# Production example: https://verbilo.co.uk
FRONTEND_URL=https://staging.verbilo.co.uk

# Optional comma-separated extra allowed origins (leave commented unless needed)
# FRONTEND_URLS=

# Optional observability
# SENTRY_DSN=

# Server (Render injects PORT automatically in production)
# PORT=3000
